# Variables de entorno para Railway
# Copia estas variables en Railway > Variables

# Secreto para autenticar llamadas entre agencIAme y este servidor
# Pon una cadena aleatoria larga — la misma debe ir en Vercel (agencIAme)
SERVER_SECRET=agenciame2026secret_cambia_esto

# URL del API de agencIAme en Vercel
AGENCIAME_API_URL=https://nexoia-soporteias-projects.vercel.app

# Firebase Admin SDK — pega el JSON completo del service account en UNA sola línea
# Lo obtienes en: Firebase Console > Configuración del proyecto > Cuentas de servicio > Generar nueva clave privada
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"nexoia-c7864","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@nexoia-c7864.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Puerto (Railway lo asigna automaticamente, no cambiar)
PORT=3001
